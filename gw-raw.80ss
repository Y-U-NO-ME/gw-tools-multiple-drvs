#!/usr/bin/env bash

# Format: 		Raw rip alias for single sided 80 track drives

# Get project name
name="$1"

# Get the passed drive letter or default to A
drive_letter="${2:A}"

# Include parent script
if [[ -f "./gw-raw" ]]
then
	parent="./gw-raw"
else
	parent="$(which gw-raw)"
fi
source "$parent" "$name" "source" "$drive_letter"

# Create dir based on name and rip within it
mkdir -p "$name"
cd "$name"
rip "$drive_letter" "c=0-79,h=0"
cd ..
